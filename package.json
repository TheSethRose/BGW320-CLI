    "exports": "publint",
    "doctor": "bun run typecheck && bun test && bun run lint && bun run deadcode && bun run exports"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "knip": "^6.14.1",
    "publint": "^0.3.21",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
