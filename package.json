{
  "name": "bgw320-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "README.md",
    "scripts",
    "skill",
    "src"
  ],
  "bin": {
    "bgw": "./src/cli.ts"
  },
  "scripts": {
    "bgw": "bun run src/cli.ts",
