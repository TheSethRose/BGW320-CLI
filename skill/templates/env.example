# Home Network Gateway CLI environment template
# Copy values into your shell/session. Do not commit real secrets.

# Router host. Defaults to 192.168.1.254 when unset.
BGW_HOST=192.168.1.254

# Alternative supported by the CLI.
# ROUTER_IP=192.168.1.254

# Device access code. Prefer providing this only for the current shell session.
# BGW_ACCESS_CODE=

# Safer pattern:
# printf '%s' "$BGW_ACCESS_CODE" | bun run src/cli.ts --access-code-stdin device status --json
